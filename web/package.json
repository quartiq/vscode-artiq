{
  "name": "web-artiq",
  "private": true,
  "type": "module",
  "dependencies": {
    "sipyco": "file:../sipyco"
  },
  "scripts": {
    "build:sipyco": "npm --prefix ../sipyco install && npm --prefix ../sipyco run build",
    "build:web": "esbuild src/* --bundle --outdir=static --format=esm",
    "build": "npm run build:sipyco && npm run build:web",

    "watch:sipyco": "npm --prefix ../sipyco run watch",
    "watch:web": "esbuild src/* --bundle --outdir=static --format=esm --watch",
    "watch": "npm-run-all -p watch:sipyco watch:web"
  }
}
